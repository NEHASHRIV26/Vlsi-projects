 1.1} .a.pane.f3.command.text.text } 
set x [guiGetTextX .a.pane.f3.command.text.text 1 1];set y [guiGetTextY .a.pane.f3.command.text.text 1 1] 
     tk::TextButton1 .a.pane.f3.command.text.text $x $y
    .a.pane.f3.command.text.text tag remove sel 0.0 end
 guiMainWinButtonRelease-1 .a.pane.f3.command.text.text
     tk::CancelRepeat

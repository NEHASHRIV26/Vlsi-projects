 guiTextKeyPress .a.pane.f3.command.text.text e
 guiTextKeyPress .a.pane.f3.command.text.text r
 guiTextKeyPress .a.pane.f3.command.text.text t
 guiTextKeyPress .a.pane.f3.command.text.text y
 guiTextKeyPress .a.pane.f3.command.text.text \ 
 guiTextKeyPress .a.pane.f3.command.text.text .

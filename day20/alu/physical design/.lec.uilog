 guiTextKeyPress .a.pane.f3.command.text.text e
 guiTextKeyPress .a.pane.f3.command.text.text a
 guiTextKeyPress .a.pane.f3.command.text.text d
 guiTextKeyPress .a.pane.f3.command.text.text \ 

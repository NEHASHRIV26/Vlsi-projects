#Gui Step(0)===>(Text).a.pane.f3.command.text.text <Button-1> 1.1
global guiReplayPause
if {[info exists guiReplayPause] && $guiReplayPause == 1} { guiReplayBreakMsg {Step 0:  (Text) <Button-1>\
 1.1} .a.pane.f3.command.text.text } 
set x [guiGetTextX .a.pane.f3.command.text.text 1 1];set y [guiGetTextY .a.pane.f3.command.text.text 1 1] 
   tkTextButton1 .a.pane.f3.command.text.text $x $y
  .a.pane.f3.command.text.text tag remove sel 0.0 end
#Gui Step(1)===>(Text).a.pane.f3.command.text.text <Button-1> 1.1
global guiReplayPause

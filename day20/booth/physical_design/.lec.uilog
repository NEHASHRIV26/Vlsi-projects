     if {$tk_strictMotif} {
	set tk::Priv(activeBg) [.a.pane.f3.command.text.vsb cget -activebackground]
	.a.pane.f3.command.text.vsb configure -activebackground [.a.pane.f3.command.text.vsb cget -background]
    }
    .a.pane.f3.command.text.vsb activate [.a.pane.f3.command.text.vsb identify 5 90]
     if {$tk_strictMotif && [info exists tk::Priv(activeBg)]} {
	.a.pane.f3.command.text.vsb configure -activebackground $tk::Priv(activeBg)
    }
    .a.pane.f3.command.text.vsb activate {}
     if {$tk_strictMotif} {
	set tk::Priv(activeBg) [.a.pane.f2.mesg.text.vsb cget -activebackground]
	.a.pane.f2.mesg.text.vsb configure -activebackground [.a.pane.f2.mesg.text.vsb cget -background]
    }
    .a.pane.f2.mesg.text.vsb activate [.a.pane.f2.mesg.text.vsb identify 4 113]
     if {$tk_strictMotif && [info exists tk::Priv(activeBg)]} {
	.a.pane.f2.mesg.text.vsb configure -activebackground $tk::Priv(activeBg)
    }
    .a.pane.f2.mesg.text.vsb activate {}

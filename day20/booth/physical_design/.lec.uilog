 guiTextKeyPress .a.pane.f3.command.text.text h
   global suffix
  set line [.a.pane.f3.command.text.text count -lines 0.0 end]
  set cmd [.a.pane.f3.command.text.text get $line.0 $line.end]
  set msg_ls [gui_main_cmd_match $cmd]
  set msg_ls_cnt [llength $msg_ls]
  if { $msg_ls_cnt == 0 } {
      #CCMPR01202506, CCMPR01185591
      #return
      break
  } elseif { $msg_ls_cnt > 1 } {
      gui_cmd_file_completion_info .a.pane.f3.command.text.text $msg_ls
      #CCMPR01202506, CCMPR01185591
      #return
      #CCMPR1716034 : sync-up tab completion for file name with batch mode (print out the suffix)
      #variable $suffix is set in uti/utirl.c gui_main_cmd_match()
      set suffix [string trim $suffix]
      if {$suffix != ""} {
         set pos [.a.pane.f3.command.text.text index insert]
         set row [lindex [split $pos .] 0]
         set ecol [lindex [split $pos .] 1]
         .a.pane.f3.command.text.text insert $row.$ecol $suffix
      }
      break
  }
  
  set ent [lindex $msg_ls 0]
  if { [gui_str_end_with $ent "..."] } {
      if { 0 } {
          #Command completion type 1
          #Need query again for complete command
          set cmd2 [string range $ent 0 [expr [string length $ent] - 4]]
          set msg2_ls [gui_main_cmd_match $cmd2]
          set msg2_ls_cnt [llength $msg2_ls]
          
          if { $msg2_ls_cnt == 0 } {
              #CCMPR01202506, CCMPR01185591
              #return
              break
          } elseif { $msg2_ls_cnt > 1 } {
              gui_cmd_file_completion_info .a.pane.f3.command.text.text $msg_ls
              
              #CCMPR01202506, CCMPR01185591
              #return
              break
          }
          
          set ent [lindex $msg2_ls 0]
      } else {
          #Command completion type 2: only complete current part
          set ent [string range $ent 0 [expr [string length $ent] - 4]]
          append ent "*"
      }
  }
  
  #Process to command/file name completion
  set pos [.a.pane.f3.command.text.text index insert]
  set row [lindex [split $pos .] 0]
  set ecol [lindex [split $pos .] 1]
  if { [gui_str_end_with $ent "*"] || [gui_str_end_with $ent "#"] } {
      #Command completion
      set cmd2 [string range $ent 0 [expr [string length $ent] - 2]]
      set cmd_tail [string range $cmd2 [string length $cmd] end]
      .a.pane.f3.command.text.text insert $row.$ecol $cmd_tail
      
      #Alex-ToDo-guiPuts "Alex-Command completion=$cmd2, $cmd_tail"
  } else {
      #File name completion
      set item [.a.pane.f3.command.text.text get $row.1 $row.$ecol]
      set name [lindex [split $item " "] end]
      set name [lindex [split $name "/"] end]
      set len [string length $name]
      if {[string first $name $ent] != -1} {
        set scol [expr $ecol - $len]
        .a.pane.f3.command.text.text delete $row.$scol $row.$ecol
        .a.pane.f3.command.text.text insert $row.$scol $ent
      } else {
        .a.pane.f3.command.text.text insert $row.$ecol $ent
      }
      #Alex-ToDo-guiPuts "Alex-File name completion=$ent"
  }
  
  #Append " " at end of command window
  set pos [.a.pane.f3.command.text.text index insert]
  set row [lindex [split $pos .] 0]
  set ecol [lindex [split $pos .] 1]
  
  set item [.a.pane.f3.command.text.text get $row.1 $row.$ecol]
  set endingchar [string index $item [expr [string length $item] - 1]]
  if {$endingchar != "/"} {
    .a.pane.f3.command.text.text insert $row.$ecol " "
  }
  
  #CCMPR01202506, CCMPR01185591
  break
